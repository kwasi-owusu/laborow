# apps/.env.example
APP_TIMEZONE=Africa/Accra
APP_ENV=production

# SMTP
SMTP_HOST=replace_with_smtp_host
SMTP_USER=replace_with_smtp_username
SMTP_PASS=replace_with_smtp_password
SMTP_PORT=465
SMTP_FROM_EMAIL=no-reply@your-domain.com
SMTP_REPLY_TO=support@your-domain.com
SMTP_FROM_NAME=Tuetra
SMTP_SECURE=smtps
SMTP_REPLY_TO_NAME=Support
SMTP_DEBUG=0

# Paystack
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_SECRET_KEY=sk_live_or_test_key_here
# SECRET_KEY is legacy Paystack compatibility. Prefer PAYSTACK_SECRET_KEY.
SECRET_KEY=sk_live_or_test_key_here
PAYSTACK_CURRENCY=GHS

# Database connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password
DB_CHARSET=utf8mb4

# Auth token signing
API_TOKEN_SECRET=replace_with_a_long_random_secret

# Google Maps browser key. Restrict this key in Google Cloud by HTTP referrer and API.
GOOGLE_MAPS_BROWSER_KEY=replace_with_restricted_browser_key

# Firebase / FCM
FIREBASE_PROJECT_ID=your_firebase_project_id
# Use a server filesystem path, not an https URL.
# Relative paths are resolved from the backend project root.
# Example: apps\notifications\controller\api\firebase_service_key.json
# Prefer storing this file outside the public web root in production.
FIREBASE_CREDENTIALS_PATH=apps\notifications\controller\api\firebase_service_key.json
